# Squalo Schwimmcoaching Berlin — Environment Variables
# Copy this file to .env and fill in real values

FLASK_ENV=production
SECRET_KEY=change-this-before-launch

# Database: Render sets DATABASE_URL automatically when you add a
# PostgreSQL database add-on.  Locally, leave it unset to use SQLite.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

DATABASE_URL=sqlite:///instance/squalo.db

# Public base URL for absolute links (emails, SEO, calendar export).
# On Render set to: https://squalo-schwimmcoaching.com
# Locally: leave unset to auto-detect from request.
# PUBLIC_BASE_URL=https://squalo-schwimmcoaching.com

BOOKING_NOTIFICATION_EMAIL=zentner.moritz@gmail.com
ADMIN_EMAIL=zentner.moritz@gmail.com
